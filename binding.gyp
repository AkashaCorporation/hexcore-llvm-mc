            "<(module_root_dir)/deps/llvm/lib/LLVMAArch64Info.lib",
            "<(module_root_dir)/deps/llvm/lib/LLVMAArch64Utils.lib",
            "<(module_root_dir)/deps/llvm/lib/LLVMMipsCodeGen.lib",
            "<(module_root_dir)/deps/llvm/lib/LLVMMipsAsmParser.lib",
