            "<(module_root_dir)/deps/llvm/lib/LLVMRISCVDisassembler.lib",
            "<(module_root_dir)/deps/llvm/lib/LLVMRISCVInfo.lib",
            "<(module_root_dir)/deps/llvm/lib/LLVMRISCVTargetMCA.lib",
